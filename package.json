{
  "name": "medical-guest-house",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:electron": "concurrently --kill-others \"npm run dev\" \"wait-on http://localhost:3000 && npx esbuild electron/main.dev.ts --bundle --platform=node --format=cjs --packages=external --outfile=electron/main.dev.cjs && npx esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=electron/preload.cjs && electron electron/main.dev.cjs\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:electron": "npm run build && esbuild electron/main.ts --bundle --platform=node --format=cjs --packages=external --outfile=electron/main.cjs && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=electron/preload.cjs",
    "dist": "npm run build:electron && electron-builder",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist release electron/main.cjs electron/main.dev.cjs electron/preload.cjs",
    "lint": "tsc --noEmit",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "build": {
    "appId": "com.medicalhouse.app",
    "productName": "نظام بيت الضيافة الطبي",
    "directories": {
      "output": "release"
    },
    "files": [
  "dist/**/*",
  "electron/main.cjs",
  "electron/preload.cjs",
  "node_modules/**/*"
],
    "extraResources": [
      {
        "from": "dist/server.cjs",
        "to": "server.cjs"
      },
      {
        "from": "sqlite_db.db",
        "to": "sqlite_db.db"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-table": "^8.21.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.0.1",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "wait-on": "^8.0.3",
    "vite": "^6.2.3"
  }
}
