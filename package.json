  "scripts": {
    "dev": "tsx server.ts",
    "build:frontend": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --define:process.env.NODE_ENV='\"production\"' --outfile=dist/server.cjs",
    "build:server:exe": "npx --yes @yao-pkg/pkg dist/server.cjs --targets node22-win-x64 --output dist/server.exe",
    "build": "npm run build:frontend && npm run build:server && npm run build:server:exe",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build && tauri build",
    "lint": "tsc --noEmit",
    "start": "node dist/server.cjs"
  },
