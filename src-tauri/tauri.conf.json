{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Medical Guest House System",
  "version": "1.0.0",
  "identifier": "com.nada.medical-guest-house",
  "build": {
    "beforeBuildCommand": "npm run build:frontend",
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3457",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../dist": "dist",
      "../dist/server.exe": "server.exe"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
